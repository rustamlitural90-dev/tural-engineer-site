---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import { sanity } from '@lib/sanity';
import { blogQuery } from '@lib/queries';

type SanityNoteListItem = {
  _id: string;
  title: string;
  slug: string;
  description?: string;
  publishDate?: string;
  mainImage?: unknown;
};

const sanityPosts = await sanity.fetch<SanityNoteListItem[]>(blogQuery);

const fallbackPosts = (await getCollection('blog'))
  .map((post) => ({
    ...post,
    data: {
      ...post.data,
      _publishedAt: (post.data.publishDate ?? post.data.date) as Date
    }
  }))
  .sort((a, b) => b.data._publishedAt.valueOf() - a.data._publishedAt.valueOf());

const posts =
  sanityPosts.length > 0
    ? sanityPosts.map((post) => ({
        slug: post.slug,
        data: {
          title: post.title,
          description: post.description ?? '',
          category: undefined as string | undefined,
          tags: [] as string[],
          _publishedAt: post.publishDate ? new Date(post.publishDate) : new Date()
        }
      }))
    : fallbackPosts;
---

<BaseLayout
  title="Engineering Notes"
  description="Technical engineering notes on slope stability, geotechnical modeling, retaining structures, and structural design decisions."
>
  <section class="section bg-white">
    <div class="container">
      <SectionHeading
        eyebrow="Notes"
        title="Decision-grade writing for ground and structures."
        description="Focused technical guides on geotechnical modeling, slope stability, retaining systems, and structural verification—written to reduce uncertainty and support buildable decisions."
      />

      <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="group rounded-2xl border border-slate-900/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
            <div class="flex flex-wrap items-center gap-3 text-xs font-bold">
              {post.data.category && (
                <span class="rounded-full border border-accent/20 bg-accent/[0.08] px-3 py-1 text-accent">
                  {post.data.category}
                </span>
              )}
              <span class="text-slate-500">
                {post.data._publishedAt.toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>

            <h2 class="mt-4 text-2xl font-extrabold leading-tight tracking-normal text-ink">
              <a class="transition group-hover:text-accent" href={`/notes/${post.slug}/`}>
                {post.data.title}
              </a>
            </h2>

            <p class="mt-3 text-sm leading-7 text-slate-600">{post.data.description}</p>

            {post.data.tags?.length ? (
              <ul class="mt-5 flex flex-wrap gap-2" aria-label="Tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <li class="rounded-full bg-mist px-3 py-1 text-xs font-semibold text-slate-600">
                    {tag}
                  </li>
                ))}
              </ul>
            ) : null}

            <a class="mt-6 inline-flex text-sm font-bold text-accent" href={`/notes/${post.slug}/`}>
              Read note
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

