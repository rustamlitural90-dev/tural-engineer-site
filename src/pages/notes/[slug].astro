---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { PortableText } from 'astro-portabletext';
import { sanity } from '@lib/sanity';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sanitySlugs = await sanity.fetch<{ slug: string }[]>(
    `*[_type == "blogPost" && defined(slug.current) && defined(publishDate) && publishDate <= now()]{
      "slug": slug.current
    }`
  );

  const bySlug = new Map<string, { slug: string; post?: (typeof posts)[number] }>();
  for (const post of posts) bySlug.set(post.slug, { slug: post.slug, post });
  for (const { slug } of sanitySlugs) bySlug.set(slug, { slug });

  return [...bySlug.values()].map((entry) => ({
    params: { slug: entry.slug },
    props: { post: entry.post ?? null }
  }));
}

type SanityNote = {
  title: string;
  slug: string;
  description?: string;
  publishDate?: string;
  body?: unknown;
};

const { post } = Astro.props as { post: CollectionEntry<'blog'> | null };
const slug = Astro.params.slug as string;

const sanityPost = await sanity.fetch<SanityNote | null>(
  `*[_type == "blogPost" && slug.current == $slug && defined(publishDate) && publishDate <= now()][0]{
    title,
    "slug": slug.current,
    description,
    publishDate,
    body
  }`,
  { slug }
);

const title = sanityPost?.title ?? post?.data.title ?? 'Note';
const description = sanityPost?.description ?? post?.data.description ?? '';
const publishedAt = sanityPost?.publishDate
  ? new Date(sanityPost.publishDate)
  : ((post?.data.publishDate ?? post?.data.date) as Date | undefined);

const FallbackContent = post ? (await render(post)).Content : null;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="section bg-white">
    <div class="container max-w-4xl">
      <p class="eyebrow">Engineering notes</p>
      <h1 class="mt-5 text-4xl font-extrabold leading-[1.08] tracking-normal text-ink md:text-5xl">
        {title}
      </h1>
      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm font-semibold text-slate-500">
        {post?.data.category && (
          <span class="rounded-full border border-accent/20 bg-accent/[0.08] px-3 py-1 text-xs font-bold text-accent">
            {post.data.category}
          </span>
        )}
        {publishedAt && (
          <span>
            Published {publishedAt.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
        )}
      </div>

      {post?.data.tags?.length ? (
        <ul class="mt-5 flex flex-wrap gap-2" aria-label="Tags">
          {post.data.tags.map((tag) => (
            <li class="rounded-full bg-mist px-3 py-1 text-xs font-semibold text-slate-600">
              {tag}
            </li>
          ))}
        </ul>
      ) : null}

      <div class="prose-engineering mt-10">
        {sanityPost?.body ? <PortableText value={sanityPost.body as any} /> : FallbackContent ? <FallbackContent /> : null}
      </div>

      <div class="mt-14 border-t border-slate-900/10 pt-8 text-sm text-slate-600">
        <p class="font-semibold text-ink">Related</p>
        <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2 font-semibold">
          <li><a class="text-accent" href="/services/">Services</a></li>
          <li><a class="text-accent" href="/projects/">Projects</a></li>
          <li><a class="text-accent" href="/contact/">Contact</a></li>
        </ul>
      </div>
    </div>
  </article>
</BaseLayout>

