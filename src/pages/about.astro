---
import BaseLayout from '@layouts/BaseLayout.astro';
import EngineeringVisual from '@components/EngineeringVisual.astro';
import SectionHeading from '@components/SectionHeading.astro';
---

<BaseLayout
  title="About"
  description="Learn about Tural Rustamli, a structural and geotechnical engineer focused on rigorous analysis, clear communication, and practical project delivery."
>
  <section class="section bg-white">
    <div class="container grid gap-12 lg:grid-cols-[0.9fr_1fr] lg:items-center">
      <div>
        <p class="eyebrow">About</p>
        <h1 class="mt-4 text-5xl font-extrabold leading-tight tracking-normal text-ink md:text-6xl">
          Structural thinking grounded in geotechnical reality.
        </h1>
        <p class="mt-6 text-xl leading-9 text-slate-600">
          Tural Rustamli works across structural and geotechnical engineering, helping teams make better design decisions where ground behavior, construction staging, and structural performance interact.
        </p>
      </div>
      <EngineeringVisual variant="section" />
    </div>
  </section>

  <section class="section bg-mist">
    <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <SectionHeading
        eyebrow="Approach"
        title="Precise analysis, practical outputs."
      />
      <div class="grid gap-5 md:grid-cols-2">
        {[
          ['Technical rigor', 'Calculations and models are built from clear assumptions, defensible parameters, and code-aware checks.'],
          ['Design communication', 'Outputs are written for decision-making, with risks, sensitivities, and next actions made explicit.'],
          ['Constructability', 'Design recommendations consider staging, temporary works, site constraints, and build sequence.'],
          ['Independent judgment', 'Models support engineering decisions; they do not replace critical review of ground and structural behavior.']
        ].map(([title, body]) => (
          <article class="rounded-2xl border border-slate-900/10 bg-white p-6">
            <h2 class="text-xl font-extrabold tracking-normal text-ink">{title}</h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
