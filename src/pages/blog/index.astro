---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';

const posts = (await getCollection('blog'))
  .map((post) => ({
    ...post,
    data: {
      ...post.data,
      _publishedAt: (post.data.publishDate ?? post.data.date) as Date
    }
  }))
  .sort((a, b) => b.data._publishedAt.valueOf() - a.data._publishedAt.valueOf());
---

<BaseLayout
  title="Engineering Notes"
  description="Technical engineering notes by Tural Rustamli on slope stability, geotechnical modeling, retaining structures, and practical structural design."
>
  <section class="section bg-white">
    <div class="container">
      <SectionHeading
        eyebrow="Engineering notes"
        title="Practical writing for structural and geotechnical decisions."
        description="Short technical guides written for engineers, contractors, and project teams who need clear reasoning instead of generic commentary."
      />
      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {posts.map((post) => (
          <article class="rounded-2xl border border-slate-900/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
            <p class="text-sm font-bold text-accent">
              {post.data._publishedAt.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
            <h2 class="mt-4 text-2xl font-extrabold leading-tight tracking-normal text-ink">
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h2>
            <p class="mt-3 text-sm leading-7 text-slate-600">{post.data.description}</p>
            <a class="mt-6 inline-flex text-sm font-bold text-accent" href={`/blog/${post.slug}/`}>Read note</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
