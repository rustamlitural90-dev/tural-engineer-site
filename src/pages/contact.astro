---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Tural Rustamli for structural engineering, geotechnical engineering, PLAXIS modeling, slope stability, retaining wall, marine, and tunnel consulting."
>
  <section class="section bg-white">
    <div class="container grid gap-12 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <SectionHeading
          eyebrow="Contact"
          title="Send a project brief or technical question."
          description="Share the context, constraints, drawings, reports, or modeling challenge. The form is prepared for a future POST /api/contact endpoint."
        />
        <div class="mt-8 rounded-2xl bg-mist p-6 text-sm leading-7 text-slate-600">
          <p class="font-bold text-ink">Email</p>
          <a class="mt-1 inline-flex font-bold text-accent" href="mailto:contact@turalengineer.com">contact@turalengineer.com</a>
        </div>
      </div>

      <form class="rounded-[28px] border border-slate-900/10 bg-white p-6 shadow-soft md:p-8" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="d0ebfc14-743c-40ca-9941-23b23166c663" />
        <input type="hidden" name="subject" value="New project request from website" />
        <input type="hidden" name="from_name" value="Tural Engineer Website" />
        <div class="grid gap-6">
          <label class="grid gap-2 text-sm font-bold text-ink">
            Name
            <input
              class="min-h-12 rounded-xl border border-slate-900/12 px-4 text-base font-medium outline-none transition focus:border-accent focus:ring-4 focus:ring-accent/10"
              type="text"
              name="name"
              autocomplete="name"
              required
            />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            Email
            <input
              class="min-h-12 rounded-xl border border-slate-900/12 px-4 text-base font-medium outline-none transition focus:border-accent focus:ring-4 focus:ring-accent/10"
              type="email"
              name="email"
              autocomplete="email"
              required
            />
          </label>
          <label class="grid gap-2 text-sm font-bold text-ink">
            Message
            <textarea
              class="min-h-44 rounded-xl border border-slate-900/12 px-4 py-3 text-base font-medium outline-none transition focus:border-accent focus:ring-4 focus:ring-accent/10"
              name="message"
              required
            ></textarea>
          </label>
          <button class="rounded-full bg-accent px-7 py-4 text-sm font-extrabold text-white transition hover:bg-ink" type="submit">
            Send project
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
