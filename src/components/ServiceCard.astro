---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="group rounded-2xl border border-slate-900/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
  <div class="mb-6 h-12 w-12 rounded-xl border border-accent/20 bg-accent/[0.08] p-3 text-accent">
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 19H20M6 19L12 5L18 19M8 14H16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>
  <h3 class="text-xl font-extrabold tracking-normal text-ink">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
</article>
