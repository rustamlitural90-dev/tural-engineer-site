---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-extrabold leading-tight tracking-normal text-ink md:text-5xl">{title}</h2>
  {description && <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>}
</div>
