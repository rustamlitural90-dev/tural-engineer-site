---
interface Props {
  title: string;
  description: string;
  location: string;
  scope: string;
  href: string;
}

const { title, description, location, scope, href } = Astro.props;
---

<article class="rounded-2xl border border-slate-900/10 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
  <p class="text-xs font-bold uppercase tracking-widest text-accent">{location}</p>
  <h3 class="mt-4 text-2xl font-extrabold leading-tight tracking-normal text-ink">
    <a href={href}>{title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{description}</p>
  <p class="mt-5 rounded-xl bg-mist px-4 py-3 text-sm font-semibold text-slate-700">{scope}</p>
  <a class="mt-6 inline-flex text-sm font-bold text-accent" href={href}>Read case study</a>
</article>
