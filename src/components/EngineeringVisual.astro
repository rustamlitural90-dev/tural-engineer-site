---
interface Props {
  variant?: 'hero' | 'contours' | 'section';
}

const { variant = 'hero' } = Astro.props;
---

<div class:list={[
  'relative overflow-hidden rounded-[28px] border border-white/15 bg-ink shadow-soft',
  variant === 'section' ? 'min-h-[320px]' : 'min-h-[430px]'
]}>
  <div class="absolute inset-0 engineering-grid opacity-70"></div>
  <div class="absolute inset-0 contour-lines"></div>
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 720 520"
    aria-hidden="true"
    role="img"
  >
    <defs>
      <linearGradient id={`beam-${variant}`} x1="72" x2="648" y1="430" y2="116">
        <stop stop-color="#2DD4BF" stop-opacity="0.92" />
        <stop offset="1" stop-color="#0757C8" stop-opacity="0.84" />
      </linearGradient>
    </defs>
    <path d="M84 426H636" stroke="white" stroke-opacity=".22" stroke-width="2" />
    <path d="M126 426L258 140L390 426" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M330 426L462 192L594 426" stroke={`url(#beam-${variant})`} stroke-width="7" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M178 312H338M416 296H540M224 222H294" stroke="#2DD4BF" stroke-opacity=".84" stroke-width="4" stroke-linecap="round" />
    <circle cx="258" cy="140" r="10" fill="#2DD4BF" />
    <circle cx="462" cy="192" r="10" fill="#0757C8" />
    <path d="M94 462C150 438 196 450 244 472C300 498 352 490 404 462C468 428 528 436 626 480" fill="none" stroke="white" stroke-opacity=".18" stroke-width="3" />
    <path d="M110 496C168 470 220 480 276 500C334 522 404 508 454 482C514 452 574 462 648 504" fill="none" stroke="#2DD4BF" stroke-opacity=".35" stroke-width="2" />
  </svg>
  <div class="absolute bottom-6 left-6 right-6 grid grid-cols-3 gap-3 text-xs font-semibold text-white/80">
    <div class="rounded-lg border border-white/10 bg-white/10 p-3 backdrop-blur">
      FEM
      <span class="mt-1 block text-white/45">modeling</span>
    </div>
    <div class="rounded-lg border border-white/10 bg-white/10 p-3 backdrop-blur">
      ULS/SLS
      <span class="mt-1 block text-white/45">checks</span>
    </div>
    <div class="rounded-lg border border-white/10 bg-white/10 p-3 backdrop-blur">
      Soil
      <span class="mt-1 block text-white/45">behavior</span>
    </div>
  </div>
</div>
